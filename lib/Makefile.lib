# ============================================
# Makefile para libsh1106
# Genera libsh1106.so y libsh1106.a
#
# Uso:
#   make -f Makefile.lib
#   sudo make -f Makefile.lib install
#   sudo make -f Makefile.lib uninstall
# ============================================

CXX      := g++
CXXFLAGS := -fPIC -O2 -Wall -Wextra -std=c++17
LDFLAGS  := -shared -lm

PREFIX   := /usr/local
INCDIR   := $(PREFIX)/include
LIBDIR   := $(PREFIX)/lib
PCDIR    := $(LIBDIR)/pkgconfig

LIB_SRC  := sh1106.cpp
LIB_OBJ  := sh1106.o
LIB_SO   := libsh1106.so
LIB_A    := libsh1106.a
PC_FILE  := sh1106.pc

VERSION  := 1.0.0

all: $(LIB_SO) $(LIB_A)

# Compilar objeto con -fPIC (necesario para .so)
$(LIB_OBJ): $(LIB_SRC) sh1106.h sh1106_ioctl.h
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Librería dinámica
$(LIB_SO): $(LIB_OBJ)
	$(CXX) $(LDFLAGS) -Wl,-soname,$(LIB_SO).$(VERSION) \
		-o $(LIB_SO) $(LIB_OBJ)
	@echo "✓ $(LIB_SO) generada"

# Librería estática
$(LIB_A): $(LIB_OBJ)
	ar rcs $(LIB_A) $(LIB_OBJ)
	@echo "✓ $(LIB_A) generada"

install: all $(PC_FILE)
	# Headers
	install -d $(INCDIR)
	install -m 644 sh1106.h $(INCDIR)/
	install -m 644 sh1106_ioctl.h $(INCDIR)/
	# Librerías
	install -d $(LIBDIR)
	install -m 755 $(LIB_SO) $(LIBDIR)/
	install -m 644 $(LIB_A)  $(LIBDIR)/
	# Symlink para el linker: libsh1106.so → libsh1106.so.1.0.0
	ln -sf $(LIBDIR)/$(LIB_SO) $(LIBDIR)/$(LIB_SO).$(VERSION)
	# pkg-config
	install -d $(PCDIR)
	install -m 644 $(PC_FILE) $(PCDIR)/
	# Actualizar cache del linker
	ldconfig
	@echo "✓ libsh1106 instalada en $(PREFIX)"
	@echo "  Headers:  $(INCDIR)/sh1106.h"
	@echo "  Lib:      $(LIBDIR)/$(LIB_SO)"
	@echo "  pkgconf:  $(PCDIR)/sh1106.pc"

uninstall:
	rm -f $(INCDIR)/sh1106.h
	rm -f $(INCDIR)/sh1106_ioctl.h
	rm -f $(LIBDIR)/$(LIB_SO)
	rm -f $(LIBDIR)/$(LIB_SO).$(VERSION)
	rm -f $(LIBDIR)/$(LIB_A)
	rm -f $(PCDIR)/sh1106.pc
	ldconfig
	@echo "✓ libsh1106 desinstalada"

clean:
	rm -f $(LIB_OBJ) $(LIB_SO) $(LIB_A) $(PC_FILE)

# Generar el fichero .pc de pkg-config
$(PC_FILE):
	@echo "prefix=$(PREFIX)"                          >  $(PC_FILE)
	@echo "exec_prefix=\$${prefix}"                  >> $(PC_FILE)
	@echo "libdir=\$${exec_prefix}/lib"              >> $(PC_FILE)
	@echo "includedir=\$${prefix}/include"           >> $(PC_FILE)
	@echo ""                                          >> $(PC_FILE)
	@echo "Name: sh1106"                             >> $(PC_FILE)
	@echo "Description: Userspace library for SH1106 OLED driver" >> $(PC_FILE)
	@echo "Version: $(VERSION)"                      >> $(PC_FILE)
	@echo "Libs: -L\$${libdir} -lsh1106 -lm"        >> $(PC_FILE)
	@echo "Cflags: -I\$${includedir}"               >> $(PC_FILE)
	@echo "✓ $(PC_FILE) generado"

.PHONY: all install uninstall clean
